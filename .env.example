NODE_ENV=development
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ACCESS_TTL_ADMIN=10m
JWT_REFRESH_TTL_ADMIN=7d
JWT_REFRESH_SECRET_ADMIN=change_me_refresh_admin
STRICT_ADMIN_AUTH_ENABLED=true
REFRESH_REUSE_DETECTION_ENABLED=true
AUTH_LOCKOUT_ENABLED=true
ADMIN_STEP_UP_AUTH_ENABLED=false
ADMIN_STEP_UP_TTL_SECONDS=300
AUTH_LOGIN_FAIL_WINDOW_MINUTES_PUBLIC=15
AUTH_LOGIN_FAIL_WINDOW_MINUTES_ADMIN=30
AUTH_LOGIN_FAIL_THRESHOLD_PUBLIC=10
AUTH_LOGIN_FAIL_THRESHOLD_ADMIN=5
AUTH_LOGIN_LOCK_MINUTES_PUBLIC=10
AUTH_LOGIN_LOCK_MINUTES_ADMIN=30
AUTH_REFRESH_RETRY_GRACE_SECONDS=20
ADMIN_IP_RESTRICTION_ENABLED=false
ADMIN_IP_ALLOWLIST=127.0.0.1,::1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sporx
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
PROMETHEUS_ENABLED=true
BACKUP_MODE=disabled
BACKUP_READ_URL=

# Supabase readiness
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_POOLER_URL=
SUPABASE_DB_DIRECT_URL=

FOOTBALL_DATA_API_KEY=
THE_SPORTS_DB_API_KEY=3
BALL_DONT_LIE_API_KEY=
API_FOOTBALL_API_KEY=
API_BASKETBALL_API_KEY=
API_NBA_API_KEY=
SPORTAPI_AI_API_KEY=
ODDS_API_IO_API_KEY=
PUBLIC_WEB_URL=http://localhost:3000
ADMIN_WEB_URL=http://localhost:3100
API_URL=http://localhost:4000
# Leave empty in production HTTPS; browser will use same-origin /api/v1 rewrite.
NEXT_PUBLIC_API_URL=
INTERNAL_API_URL=http://localhost:4000
SERVICE_ROLE=api
PROVIDER_HTTP_TIMEOUT_MS=12000
PROVIDER_HTTP_RETRIES=1
INGESTION_STALE_RUN_MINUTES=15
ENABLE_EMBEDDED_INGESTION_WORKER=false
INGESTION_WORKER_CONCURRENCY=1
SYNC_INTERVAL_DEFAULT_MINUTES=120
SYNC_INTERVAL_MATCH_DAY_MINUTES=30
SCHEDULER_LOCK_KEY=jobs-scheduler
SCHEDULER_LOCK_TTL_MS=55000
SCHEDULER_TICK_MS=180000
SCHEDULER_STALE_RECOVERY_INTERVAL_MS=300000
TRUST_PROXY=true
RATE_LIMIT_DEFAULT_LIMIT=300
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN_LIMIT=10
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REFRESH_LIMIT=30
RATE_LIMIT_AUTH_REFRESH_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_WRITE_LIMIT=60
RATE_LIMIT_ADMIN_WRITE_WINDOW_SECONDS=60

# Security phase 3 flags
SECURITY_AUDIT_ENABLED=true
SECURITY_EVENT_STREAM_ENABLED=true
INCIDENT_READINESS_ENABLED=true
EMERGENCY_CONTROLS_ENABLED=true
SECURITY_ALERTING_ENABLED=true

# Security phase 4 flags
SECRET_GOVERNANCE_ENABLED=true
STRICT_API_VALIDATION_ENABLED=true
STRICT_CORS_ENABLED=true
STRICT_SECURITY_HEADERS_ENABLED=true
QUEUE_SECURITY_ENFORCED=true
RUNTIME_HARDENING_CHECKS_ENABLED=true
VULNERABILITY_GATE_ENABLED=true
ADMIN_SECURITY_BOUNDARY_ENABLED=true
INTERNAL_SERVICE_IDENTITIES=api,worker
ADMIN_ALLOWED_ORIGINS=http://localhost:3100
ADMIN_ALLOWED_IPS=
API_REQUEST_BODY_LIMIT_BYTES=262144
SECURITY_CSP=
PUBLIC_WEB_CSP=
ADMIN_WEB_CSP=

# Security phase 5 flags
PRIVACY_GOVERNANCE_ENABLED=true
RETENTION_CLEANUP_ENABLED=true
PRIVACY_EXPORT_ENABLED=true
PRIVACY_DELETION_ENABLED=true
LEGAL_HOLD_HOOKS_ENABLED=true
COMPLIANCE_POLICY_ENFORCED=true
COMPLIANCE_POLICY_VERSION=v1
LEGAL_HOLD_DOMAINS=
