generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IngestionStatus {
  queued
  running
  succeeded
  failed
}

enum MatchStatus {
  scheduled
  live
  finished
  postponed
  cancelled
}

enum PlayerAvailabilityStatus {
  AVAILABLE
  BENCH
  OUT
  SUSPENDED
  INJURY_UNKNOWN
}

enum PublishDecisionStatus {
  APPROVED
  ABSTAINED
  SUPPRESSED
  BLOCKED
  MANUALLY_FORCED
}

enum ManualOverrideAction {
  FORCE
  BLOCK
}

enum ServingAliasType {
  CHAMPION
  CHALLENGER
  SHADOW
  CANARY
  ROLLBACK_CANDIDATE
  RETIRED
}

enum PromotionDecisionStatus {
  PROMOTE
  KEEP_CHAMPION
  EXTEND_SHADOW
  BLOCK_PROMOTION
  FORCE_PROMOTE
  FORCE_KEEP
}

enum DriftSeverity {
  INFO
  WARNING
  CRITICAL
}

enum DriftMonitorCategory {
  UNLABELED
  LABELED
}

enum RetrainingTriggerType {
  SCHEDULE
  DRIFT_THRESHOLD
  NEW_LABELS
  MANUAL
  CANARY_UNDERPERFORMANCE
  SEASONAL_RESET
}

enum LifecycleRunStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum BankrollAccountMode {
  PAPER
  SANDBOX
  LIVE_DISABLED
}

enum BankrollProfileKey {
  FLAT_UNIT
  FRACTIONAL_KELLY
  CAPPED_FRACTIONAL_KELLY
  RISK_BUDGETED
}

enum StakeDecisionStatus {
  CREATED
  NO_STAKE
  SIZED
  CLIPPED
  BLOCKED
  SKIPPED
}

enum TicketDecisionStatus {
  CREATED
  CLIPPED
  BLOCKED
  SKIPPED
  EXECUTED_PAPER
}

enum PaperOrderStatus {
  OPEN
  WON
  LOST
  VOID
  PUSH
  HALF_WON
  HALF_LOST
  CANCELLED
}

enum RoiGovernanceStatus {
  HEALTHY
  WATCH
  THROTTLED
  BLOCKED
  MANUAL_OVERRIDE
}

enum ExposureLimitBehavior {
  ALLOW
  CLIP
  BLOCK
}

enum ExposureScopeType {
  MATCH
  LEAGUE
  SPORT
  MARKET_FAMILY
  HORIZON
  CALENDAR_DAY
  ROLLING_7D
  OPEN_TOTAL
  CONCURRENT_OPEN
}

enum BankrollLedgerEntryType {
  ORDER_OPEN
  ORDER_SETTLE
  MANUAL_ADJUSTMENT
  RESERVE_RELEASE
  RECOMPUTE_CORRECTION
}

enum SimulationRunStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum ResearchRunStatus {
  queued
  running
  succeeded
  failed
  cancelled
  pruned
}

enum TuningSearchType {
  GRID
  RANDOM
  OPTUNA_COMPAT
}

enum StrategyObjective {
  LOG_GROWTH
  ROI
  YIELD
  MIN_MAX_DRAWDOWN
  SHARPE
  CALIBRATION_QUALITY
  RISK_OF_RUIN
  COMPOSITE
}

enum PolicyCandidateStatus {
  DRAFT
  CANDIDATE
  UNDER_REVIEW
  APPROVED_FOR_SHADOW
  APPROVED_FOR_CANARY
  REJECTED
  RETIRED
}

enum PolicyPromotionDecisionStatus {
  APPROVE_SHADOW
  APPROVE_CANARY
  REQUIRE_MORE_EVIDENCE
  REJECT
  FORCE_APPROVE
  FORCE_REJECT
}

enum AuthActorType {
  PUBLIC
  ADMIN
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
  LOCKED
}

enum RefreshTokenEventType {
  ISSUED
  ROTATED
  REVOKED
  REUSE_DETECTED
  FAMILY_REVOKED
}

enum LoginAttemptResult {
  SUCCESS
  FAILURE
  LOCKED
}

enum AuthRiskSeverity {
  INFO
  WARNING
  HIGH
  CRITICAL
}

enum AuthRiskType {
  BRUTE_FORCE
  TOKEN_REUSE
  ADMIN_IP_BLOCKED
  STEP_UP_FAILURE
  STEP_UP_SUCCESS
  GLOBAL_LOGOUT
  SESSION_REVOKED
}

enum AdminStepUpStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  isActive      Boolean        @default(true)
  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  refreshTokenFamilies RefreshTokenFamily[]
  authSessions  AuthSession[]
  loginAttempts LoginAttempt[]
  authRiskEvents AuthRiskEvent[]
  adminAccessSessions AdminAccessSession[]
  adminStepUpChallenges AdminStepUpChallenge[]
  refreshTokenEvents RefreshTokenEvent[]
  auditLogs     AuditLog[]
  apiLogs       ApiLog[]
  manualPublishOverrides ManualPublishOverride[] @relation("ManualPublishOverrideActor")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenJti  String?   @unique
  familyId  String?
  sessionId String?
  actorType AuthActorType @default(PUBLIC)
  tokenHash String
  usedAt    DateTime?
  expiresAt DateTime
  revokedAt DateTime?
  revokedReason String?
  replacedByTokenId String?
  deviceFingerprint String?
  ipAddress String?
  userAgent String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    RefreshTokenFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)
  session   AuthSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  events    RefreshTokenEvent[] @relation("RefreshTokenEventToken")
  replacedByToken RefreshToken? @relation("RefreshTokenReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull)
  replacesTokens RefreshToken[] @relation("RefreshTokenReplacement")
  createdAt DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([sessionId])
}

model AuthSession {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  actorType         AuthActorType      @default(PUBLIC) @map("actor_type")
  status            AuthSessionStatus  @default(ACTIVE)
  sessionKey        String             @unique @map("session_key")
  ipAddress         String?            @map("ip")
  userAgent         String?            @map("user_agent")
  deviceFingerprint String?            @map("device_fingerprint")
  environment       String?
  lastSeenAt        DateTime           @default(now()) @map("last_seen_at")
  expiresAt         DateTime           @map("expires_at")
  revokedAt         DateTime?          @map("revoked_at")
  revokedReason     String?            @map("revoked_reason")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens     RefreshToken[]
  refreshTokenFamilies RefreshTokenFamily[]
  authRiskEvents    AuthRiskEvent[]
  adminAccessSession AdminAccessSession?
  adminStepUpChallenges AdminStepUpChallenge[]

  @@index([userId, status, lastSeenAt])
  @@map("auth_sessions")
}

model RefreshTokenFamily {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  sessionId     String?           @map("session_id")
  actorType     AuthActorType     @default(PUBLIC) @map("actor_type")
  status        AuthSessionStatus @default(ACTIVE)
  revokedAt     DateTime?         @map("revoked_at")
  revokedReason String?           @map("revoked_reason")
  lastRotatedAt DateTime?         @map("last_rotated_at")
  expiresAt     DateTime?         @map("expires_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session       AuthSession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  tokens        RefreshToken[]
  events        RefreshTokenEvent[]
  authRiskEvents AuthRiskEvent[]

  @@index([userId, status, createdAt])
  @@index([sessionId])
  @@map("refresh_token_families")
}

model RefreshTokenEvent {
  id        String                @id @default(uuid())
  userId    String?               @map("user_id")
  familyId  String?               @map("family_id")
  tokenId   String?               @map("token_id")
  eventType RefreshTokenEventType @map("event_type")
  reason    String?
  ipAddress String?               @map("ip")
  userAgent String?               @map("user_agent")
  metadata  Json?
  createdAt DateTime              @default(now()) @map("created_at")
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  family    RefreshTokenFamily?   @relation(fields: [familyId], references: [id], onDelete: SetNull)
  token     RefreshToken?         @relation("RefreshTokenEventToken", fields: [tokenId], references: [id], onDelete: SetNull)

  @@index([familyId, createdAt])
  @@index([userId, createdAt])
  @@map("refresh_token_events")
}

model LoginAttempt {
  id          String            @id @default(uuid())
  userId      String?           @map("user_id")
  actorType   AuthActorType     @default(PUBLIC) @map("actor_type")
  email       String?
  ipAddress   String?           @map("ip")
  userAgent   String?           @map("user_agent")
  result      LoginAttemptResult
  reason      String?
  riskScore   Int               @default(0) @map("risk_score")
  lockedUntil DateTime?         @map("locked_until")
  createdAt   DateTime          @default(now()) @map("created_at")
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, ipAddress, createdAt])
  @@index([actorType, result, createdAt])
  @@map("login_attempts")
}

model AuthRiskEvent {
  id         String           @id @default(uuid())
  userId     String?          @map("user_id")
  sessionId  String?          @map("session_id")
  familyId   String?          @map("family_id")
  actorType  AuthActorType    @default(PUBLIC) @map("actor_type")
  riskType   AuthRiskType     @map("risk_type")
  severity   AuthRiskSeverity @default(WARNING)
  reason     String?
  ipAddress  String?          @map("ip")
  userAgent  String?          @map("user_agent")
  metadata   Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  session    AuthSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  family     RefreshTokenFamily? @relation(fields: [familyId], references: [id], onDelete: SetNull)

  @@index([riskType, severity, createdAt])
  @@index([actorType, createdAt])
  @@index([userId, createdAt])
  @@map("auth_risk_events")
}

model AdminAccessSession {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  sessionId        String            @unique @map("session_id")
  status           AuthSessionStatus @default(ACTIVE)
  stepUpRequired   Boolean           @default(false) @map("step_up_required")
  stepUpVerifiedAt DateTime?         @map("step_up_verified_at")
  ipAddress        String?           @map("ip")
  userAgent        String?           @map("user_agent")
  allowedIp        Boolean?          @map("allowed_ip")
  reason           String?
  createdAt        DateTime          @default(now()) @map("created_at")
  lastSeenAt       DateTime          @default(now()) @map("last_seen_at")
  revokedAt        DateTime?         @map("revoked_at")
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          AuthSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@map("admin_access_sessions")
}

model AdminStepUpChallenge {
  id            String            @id @default(uuid())
  userId        String            @map("user_id")
  sessionId     String?           @map("session_id")
  status        AdminStepUpStatus @default(PENDING)
  challengeHash String            @map("challenge_hash")
  expiresAt     DateTime          @map("expires_at")
  verifiedAt    DateTime?         @map("verified_at")
  failedAttempts Int              @default(0) @map("failed_attempts")
  maxAttempts   Int               @default(3) @map("max_attempts")
  ipAddress     String?           @map("ip")
  userAgent     String?           @map("user_agent")
  reason        String?
  createdAt     DateTime          @default(now()) @map("created_at")
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session       AuthSession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([sessionId, status, createdAt])
  @@map("admin_step_up_challenges")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
}

model Sport {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  leagues   League[]
  matches   Match[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model League {
  id               String                  @id @default(uuid())
  sportId          String
  name             String
  code             String?
  country          String?
  dataSource       String?
  dataQualityScore Float?
  importedAt       DateTime?
  updatedByProcess String?
  sport            Sport                   @relation(fields: [sportId], references: [id])
  seasons          Season[]
  matches          Match[]
  providerMappings ProviderLeagueMapping[]
  publishStrategyProfiles PublishStrategyProfile[]
  modelRegistryEntries ModelRegistryEntry[]
  modelAliases     ModelAlias[]
  calibrationAliases CalibrationAlias[]
  challengerEvaluations ChallengerEvaluation[]
  trainingDatasets TrainingDataset[]
  trainingRuns     TrainingRun[]
  promotionDecisions PromotionDecision[]
  rollbackEvents   RollbackEvent[]
  driftMonitors    DriftMonitor[]
  driftEvents      DriftEvent[]
  retrainingTriggers RetrainingTrigger[]
  shadowEvalRuns   ShadowEvalRun[]
  rolloutAssignments RolloutAssignment[]
  labelCollectionRuns LabelCollectionRun[]
  modelHealthSnapshots ModelHealthSnapshot[]
  policyAliases     PolicyAlias[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([sportId, name])
}

model Season {
  id               String     @id @default(uuid())
  leagueId         String
  yearLabel        String
  startDate        DateTime?
  endDate          DateTime?
  dataSource       String?
  dataQualityScore Float?
  importedAt       DateTime?
  updatedByProcess String?
  league           League     @relation(fields: [leagueId], references: [id])
  matches          Match[]
  standings        Standing[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([leagueId, yearLabel])
}

model Team {
  id               String                @id @default(uuid())
  name             String
  shortName        String?
  country          String?
  foundedYear      Int?
  dataSource       String?
  dataQualityScore Float?
  importedAt       DateTime?
  updatedByProcess String?
  homeMatches      Match[]               @relation("HomeTeam")
  awayMatches      Match[]               @relation("AwayTeam")
  teamStats        TeamStat[]
  players          Player[]
  providerMappings ProviderTeamMapping[]
  standings        Standing[]
  basketballStats  BasketballTeamStat[]
  canonicalLineups CanonicalLineup[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([name, country])
}

model Player {
  id               String       @id @default(uuid())
  teamId           String?
  fullName         String
  position         String?
  birthDate        DateTime?
  nationality      String?
  dataSource       String?
  dataQualityScore Float?
  importedAt       DateTime?
  updatedByProcess String?
  team             Team?        @relation(fields: [teamId], references: [id])
  stats            PlayerStat[]
  lineupEntries    CanonicalLineupPlayerAvailability[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Match {
  id                      String                   @id @default(uuid())
  sportId                 String
  leagueId                String
  seasonId                String
  homeTeamId              String
  awayTeamId              String
  divisionCode            String?
  matchDateTimeUTC        DateTime
  status                  MatchStatus              @default(scheduled)
  homeScore               Int?
  awayScore               Int?
  halfTimeHomeScore       Int?
  halfTimeAwayScore       Int?
  q1HomeScore             Int?
  q1AwayScore             Int?
  q2HomeScore             Int?
  q2AwayScore             Int?
  q3HomeScore             Int?
  q3AwayScore             Int?
  q4HomeScore             Int?
  q4AwayScore             Int?
  resultCode              String?
  oddsHome                Float?
  oddsDraw                Float?
  oddsAway                Float?
  maxOddsHome             Float?
  maxOddsDraw             Float?
  maxOddsAway             Float?
  over25                  Float?
  under25                 Float?
  maxOver25               Float?
  maxUnder25              Float?
  homeElo                 Float?
  awayElo                 Float?
  form3Home               Float?
  form5Home               Float?
  form3Away               Float?
  form5Away               Float?
  dataSource              String?
  dataQualityScore        Float?
  importedAt              DateTime?
  updatedByProcess        String?
  mappingConfidence       Float?
  sport                   Sport                    @relation(fields: [sportId], references: [id])
  league                  League                   @relation(fields: [leagueId], references: [id])
  season                  Season                   @relation(fields: [seasonId], references: [id])
  homeTeam                Team                     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam                Team                     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  events                  MatchEvent[]
  teamStats               TeamStat[]
  basketballStats         BasketballTeamStat[]
  playerStats             PlayerStat[]
  prediction              Prediction?
  featureSnapshots        MatchFeatureSnapshot[]
  providerMappings        ProviderMatchMapping[]
  oddsSnapshots           OddsSnapshot[]
  oddsSnapshotsV2         OddsSnapshotV2[]
  oddsMappings            MatchOddsMapping[]
  marketAnalysisSnapshots MarketAnalysisSnapshot[]
  canonicalLineups        CanonicalLineup[]
  canonicalRevisions      CanonicalMatchRevision[]
  featureSnapshotsV2      FeatureSnapshot[]
  lineupSnapshots         LineupSnapshot[]
  eventAggregateSnapshots EventAggregateSnapshot[]
  marketConsensusSnapshots MarketConsensusSnapshot[]
  predictionRuns          PredictionRun[]
  predictionCandidates    PredictionCandidate[]
  publishDecisions        PublishDecision[]
  metaModelRuns           MetaModelRun[]
  datasetSnapshots        DatasetSnapshot[]
  publishedPredictions    PublishedPrediction[]
  manualPublishOverrides  ManualPublishOverride[]
  policyEvaluationSnapshots PolicyEvaluationSnapshot[]
  shadowComparisons       ShadowPredictionComparison[]
  leakageChecks           LeakageCheckResult[]
  stakeCandidates         StakeCandidate[]
  ticketLegs              TicketLeg[]
  teamComparisonCache     TeamComparisonCache[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@unique([sportId, leagueId, seasonId, matchDateTimeUTC, homeTeamId, awayTeamId])
  @@index([leagueId, seasonId, matchDateTimeUTC])
  @@index([status, matchDateTimeUTC])
  @@index([homeTeamId, status, matchDateTimeUTC])
  @@index([awayTeamId, status, matchDateTimeUTC])
}

model MatchEvent {
  id               String    @id @default(uuid())
  matchId          String
  minute           Int?
  eventType        String
  teamId           String?
  playerId         String?
  payload          Json?
  dataSource       String?
  importedAt       DateTime?
  updatedByProcess String?
  match            Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
}

model TeamStat {
  id              String    @id @default(uuid())
  matchId         String
  teamId          String
  possession      Float?
  shots           Int?
  shotsOnTarget   Int?
  fouls           Int?
  corners         Int?
  yellowCards     Int?
  redCards        Int?
  tempo           Float?
  offenseScore    Float?
  defenseScore    Float?
  setPieceScore   Float?
  transitionScore Float?
  dataSource      String?
  importedAt      DateTime?
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team            Team      @relation(fields: [teamId], references: [id])
  createdAt       DateTime  @default(now())

  @@unique([matchId, teamId])
}

model PlayerStat {
  id            String    @id @default(uuid())
  matchId       String
  playerId      String
  teamId        String?
  minutesPlayed Int?
  goals         Int?
  assists       Int?
  shots         Int?
  passes        Int?
  tackles       Int?
  dataSource    String?
  importedAt    DateTime?
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player        Player    @relation(fields: [playerId], references: [id])
  createdAt     DateTime  @default(now())

  @@unique([matchId, playerId])
}

model Standing {
  id           String   @id @default(uuid())
  seasonId     String
  teamId       String
  played       Int      @default(0)
  won          Int      @default(0)
  draw         Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  points       Int      @default(0)
  rank         Int?
  season       Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  team         Team     @relation(fields: [teamId], references: [id])
  updatedAt    DateTime @updatedAt

  @@unique([seasonId, teamId])
}

model Prediction {
  id                        String                     @id @default(uuid())
  matchId                   String                     @unique
  modelVersionId            String?
  probabilities             Json
  expectedScore             Json
  rawProbabilities          Json
  calibratedProbabilities   Json
  rawConfidenceScore        Float
  calibratedConfidenceScore Float
  confidenceScore           Float
  summary                   String
  riskFlags                 Json
  isRecommended             Boolean                    @default(false)
  isLowConfidence           Boolean                    @default(false)
  avoidReason               String?
  dataSource                String?
  importedAt                DateTime?
  updatedByProcess          String?
  match                     Match                      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  explanation               PredictionExplanation?
  failedAnalyses            FailedPredictionAnalysis[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@index([createdAt])
  @@index([confidenceScore, isLowConfidence])
}

model BasketballTeamStat {
  id                        String    @id @default(uuid())
  matchId                   String
  teamId                    String
  possessions               Float?
  offensiveRating           Float?
  defensiveRating           Float?
  netRating                 Float?
  pace                      Float?
  effectiveFgPct            Float?
  trueShootingPct           Float?
  turnoverPct               Float?
  offensiveReboundPct       Float?
  defensiveReboundPct       Float?
  freeThrowRate             Float?
  threePointAttemptRate     Float?
  pointsInPaint             Int?
  secondChancePoints        Int?
  fastBreakPoints           Int?
  benchPoints               Int?
  assistRatio               Float?
  assistToTurnoverRatio     Float?
  stealRate                 Float?
  blockRate                 Float?
  foulRate                  Float?
  playerAvailabilityScore   Float?
  lineupContinuityScore     Float?
  topUsageAvailabilityScore Float?
  backToBack                Boolean   @default(false)
  thirdGameInFourNights     Boolean   @default(false)
  travelLoad                Float?
  overtimeLastGame          Boolean   @default(false)
  gameContext               String?
  mustWinPressure           Float?
  dataSource                String?
  importedAt                DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  match                     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team                      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamId])
  @@index([teamId, createdAt])
}

model PredictionExplanation {
  id           String     @id @default(uuid())
  predictionId String     @unique
  content      Json
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model FeatureSet {
  id         String                 @id @default(uuid())
  name       String
  version    String
  definition Json
  active     Boolean                @default(true)
  snapshots  MatchFeatureSnapshot[]
  createdAt  DateTime               @default(now())

  @@unique([name, version])
}

model MatchFeatureSnapshot {
  id           String     @id @default(uuid())
  matchId      String
  featureSetId String
  features     Json
  generatedAt  DateTime   @default(now())
  match        Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  featureSet   FeatureSet @relation(fields: [featureSetId], references: [id])

  @@unique([matchId, featureSetId])
}

model ModelVersion {
  id                    String                       @id @default(uuid())
  sportId               String?
  modelName             String
  version               String
  trainingWindow        String?
  parameters            Json?
  active                Boolean                      @default(false)
  backtests             BacktestResult[]
  calibrations          PredictionCalibration[]
  performanceTimeseries ModelPerformanceTimeseries[]
  featureImportance     FeatureImportanceSnapshot[]
  comparisonSnapshots   ModelComparisonSnapshot[]
  predictionRuns        PredictionRun[]
  predictionCandidates  PredictionCandidate[]
  publishDecisions      PublishDecision[]
